{
  "name": "@pos-360/touch-id",
  "version": "2.2.1",
  "description": "The Touch ID API is used to interface with fingerprint scanning hardware.",
  "keywords": [
    "touch",
    "id",
    "fingerprint",
    "scanner",
    "hardware",
    "security",
    "auth",
    "authentication",
    "biometric",
    "biometrics",
    "secugen"
  ],
  "bugs": {
    "url": "https://github.com/POS-360/touch-id/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/POS-360/touch-id.git"
  },
  "license": "MIT",
  "author": "Blayke LaRue",
  "main": "rolledup/index.js",
  "module": "rolledup/index.es.js",
  "browser": "rolledup/index.umd.js",
  "types": "rolledup/index.d.ts",
  "files": [
    "/src/library/*",
    "/rolledup",
    "/prebuilds",
    "/third_party",
    "package.json",
    "binding.gyp"
  ],
  "gypfile": true,
  "scripts": {
    "build": "run-s clean prebuild build:tsc build:rollup",
    "prebuild": "run-script-os",
    "prebuild:win32": "npm run prebuild:x64",
    "prebuild:darwin": "npm run prebuild:x64 && npm run prebuild:arm64",
    "prebuild:x64": "prebuildify --napi --electron-compat --strip --arch x64 --verbose",
    "prebuild:ia32": "prebuildify --napi --electron-compat --strip --arch ia32 --verbose",
    "prebuild:arm64": "prebuildify --napi --electron-compat --strip --arch arm64 --verbose",
    "build:tsc": "npm run tsc:compile",
    "build:rollup": "npm run rollup:compile",
    "install": "node-gyp-build",
    "rebuild": "node-gyp rebuild",
    "clean": "node-gyp clean && rimraf prebuilds && rimraf rolledup && rimraf compiled",
    "rollup:compile": "rollup -c",
    "rollup:compile:watch": "rollup -c -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "tsc:compile": "tsc",
    "tsc:compile:watch": "tsc --watch"
  },
  "dependencies": {
    "bindings": "^1.5.0",
    "node-addon-api": "^7.0.0",
    "node-gyp-build": "^4.6.1"
  },
  "devDependencies": {
    "@babel/types": "^7.23.0",
    "@rollup/plugin-commonjs": "^25.0.5",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@types/bindings": "^1.5.2",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.4",
    "@typescript-eslint/eslint-plugin": "^6.7.5",
    "@typescript-eslint/parser": "^6.7.5",
    "eslint": "^8.51.0",
    "jest": "^29.7.0",
    "jsdoc-to-markdown": "^8.0.0",
    "npm-run-all": "^4.1.5",
    "prebuildify": "^5.0.1",
    "rimraf": "^5.0.5",
    "rollup": "^3.29.4",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-node-externals": "^6.1.2",
    "rollup-plugin-polyfill-node": "^0.12.0",
    "run-script-os": "^1.1.6",
    "tar-fs": "^3.0.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "uglifyjs": "^2.4.11"
  }
}
