{
    "variables": {
        "openssl_fips": "",
    },
    "win_delay_load_hook": "true",
    "targets": [
        {
            "target_name": "secugen",
            "sources": [],
            "cflags!": ["-fno-exceptions"],
            "cflags_cc!": ["-fno-exceptions"],
            "include_dirs": [
                "<!@(node -p \"require('node-addon-api').include\")",
            ],
            'defines': [ 'NAPI_DISABLE_CPP_EXCEPTIONS' ],
            "dependencies": ["<!(node -p \"require('node-addon-api').gyp\")"],
            "conditions": [
                [
                    "OS=='win'",
                    {
                        "defines": [
                            "_HAS_EXCEPTIONS=1",
                            "UNICODE",
                            "_CRT_SECURE_NO_WARNINGS",
                            "WIN32",
                            "_WINDOWS",
                            "LOGURU_DEBUG_LOGGING=0",
                        ],
                        "msvs_settings": {"VCCLCompilerTool": {"ExceptionHandling": 1}},
                        "sources": [
                            "src/library/secugen_win.cc",
                            "src/library/loguru.cpp",
                            "src/library/base64.cpp",
                            "src/library/utils.cc",
                        ],
                        'include_dirs': [
                            "<(module_root_dir)/third_party/secugen/Inc",
                        ],
                        "libraries": [
                            "<(module_root_dir)/third_party/secugen/Lib/x64/sgfplib.lib",
                        ],
                        "copies": [
                            {
                                "destination": "./build/Release",
                                "files": [
                                    "<(module_root_dir)/third_party/secugen/Bin/x64/sgfplib.dll",
                                    "<(module_root_dir)/third_party/secugen/Bin/x64/sgbledev.dll",
                                    "<(module_root_dir)/third_party/secugen/Bin/x64/sgfdusdax64.dll",
                                    "<(module_root_dir)/third_party/secugen/Bin/x64/sgfpamx.dll",
                                    "<(module_root_dir)/third_party/secugen/Bin/x64/sgwsqlib.dll",
                                ],
                            },
                        ],
                    },
                ],
                [
                    "OS=='mac'",
                    {
                        "defines": [ '__MACOS__' ],
                        "sources": [
                            "src/library/secugen_mac.cc",
                        ],
                        'xcode_settings': {
                            'GCC_ENABLE_CPP_EXCEPTIONS': 'YES',
                            'CLANG_CXX_LIBRARY': 'libc++',
                            'MACOSX_DEPLOYMENT_TARGET': '10.15'
                        },
                    },
                ],
            ],
        }
    ],
}
